{
  "kind": "collectionType",
  "collectionName": "program_statuses",
  "info": {
    "singularName": "program-status",
    "pluralName": "program-statuses",
    "displayName": "Program_Status"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "symbol_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "score": {
      "type": "integer",
      "required": true
    },
    "program_skill": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::program-skill.program-skill",
      "inversedBy": "program_statuses"
    },
    "comments": {
      "type": "customField",
      "customField": "plugin::ckeditor5.CKEditor",
      "options": {
        "preset": "defaultHtml"
      }
    },
    "name": {
      "type": "string"
    }
  }
}
